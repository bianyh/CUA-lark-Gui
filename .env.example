OPENAI_API_KEY=replace-with-your-key
OPENAI_BASE_URL=https://api.chattoken.cc/v1
OPENAI_MODEL=gpt-4o
CUA_WINDOW_TITLE_KEYWORD=飞书
CUA_MAX_STEPS=15
CUA_MAX_RETRIES=2
CUA_MOCK_MODE=true
CUA_OCR_BACKEND=none
CUA_PADDLE_OCR_LANG=ch
CUA_RUNTIME_LOGS=true
CUA_RUNTIME_PREVIEW_CHARS=80
CUA_LOAD_WAIT_ENABLED=true
CUA_LOAD_MAX_WAIT_ROUNDS=4
CUA_LOAD_POLL_INTERVAL_MS=700
CUA_LOAD_SIMILARITY_THRESHOLD=0.992
CUA_API_IMAGE_MAX_SIDE=1280
CUA_API_MULTI_IMAGE_MAX_SIDE=960
CUA_API_IMAGE_JPEG_QUALITY=75
CUA_COORDINATE_MODE=api_image
